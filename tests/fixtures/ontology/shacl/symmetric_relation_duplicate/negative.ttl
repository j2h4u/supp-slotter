@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ss: <https://j2h4u.github.io/supp-slotter/ontology/v1/> .

ss:rt a ss:RelationType ; ss:symmetric true .
ss:r1 a ss:Relation ; ss:relationType ss:rt ; ss:sourceSelector ss:r1s ; ss:targetSelector ss:r1t .
ss:r2 a ss:Relation ; ss:relationType ss:rt ; ss:sourceSelector ss:r2s ; ss:targetSelector ss:r2t .
ss:r1s a ss:Selector ; ss:selectsTerm ss:lt .
ss:r1t a ss:Selector ; ss:selectsTerm ss:rtm .
ss:r2s a ss:Selector ; ss:selectsTerm ss:lt .
ss:r2t a ss:Selector ; ss:selectsTerm ss:rtm .
ss:lt a ss:OntologyTerm ; ss:semanticCategory ss:kind ; ss:ontocleanProfile ss:rigid_identity .
ss:rtm a ss:OntologyTerm ; ss:semanticCategory ss:kind ; ss:ontocleanProfile ss:rigid_identity .
