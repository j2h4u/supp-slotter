@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ss: <https://j2h4u.github.io/supp-slotter/ontology/v1/> .

ss:rt a ss:RelationType ; ss:symmetric true .
ss:r a ss:Relation ; ss:relationType ss:rt ; ss:sourceSelector ss:source ; ss:targetSelector ss:target .
ss:source a ss:Selector ; ss:selectsTerm ss:lt .
ss:target a ss:Selector ; ss:selectsTerm ss:lt .
ss:lt a ss:OntologyTerm ; ss:semanticCategory ss:kind ; ss:ontocleanProfile ss:rigid_identity .
