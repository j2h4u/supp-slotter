{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Goal Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "retired"]
    },
    "started": {
      "type": "string",
      "minLength": 1
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status"],
        "properties": {
          "substance": {
            "type": "string",
            "pattern": "^sub_[a-z0-9]{10}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["taking", "candidate", "declined"]
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "oneOf": [
          {"required": ["substance"]},
          {"required": ["name"]}
        ]
      }
    }
  }
}
