{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Product Formula Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "components"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^prd_[a-z0-9]{10}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["substance"],
        "properties": {
          "substance": {
            "type": "string",
            "pattern": "^sub_[a-z0-9]{10}$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          },
          "primary": {
            "type": "boolean"
          }
        }
      }
    },
    "brand": {
      "type": "string",
      "minLength": 1
    },
    "urls": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "unmatched_concerns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
