{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Supplement Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "stacks"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "stacks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["daily", "training", "inactive"],
      "properties": {
        "daily": { "$ref": "#/$defs/stackItems" },
        "training": { "$ref": "#/$defs/stackItems" },
        "inactive": { "$ref": "#/$defs/stackItems" }
      }
    }
  },
  "$defs": {
    "stackItems": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^prd_[a-z0-9]{10}$"
      }
    }
  }
}
