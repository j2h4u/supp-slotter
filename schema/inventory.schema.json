{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Supplement Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "stacks"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "stacks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["daily", "training", "inactive"],
      "properties": {
        "daily": { "$ref": "#/$defs/stackItems" },
        "training": { "$ref": "#/$defs/stackItems" },
        "inactive": { "$ref": "#/$defs/stackItems" }
      }
    }
  },
  "$defs": {
    "stackItems": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["product"],
        "properties": {
          "product": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "notes": {
            "type": "string",
            "minLength": 1
          },
          "traits_override": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "add": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z]+:[a-z][a-z0-9_]*$"
                }
              },
              "remove": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z]+:[a-z][a-z0-9_]*$"
                }
              }
            }
          }
        }
      }
    }
  }
}
