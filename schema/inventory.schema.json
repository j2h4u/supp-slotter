{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Supplement Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "supplements"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "supplements": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["product", "stack"],
        "properties": {
          "product": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "stack": {
            "type": "string",
            "enum": ["daily", "training", "inactive"]
          },
          "dose": {
            "type": "string",
            "minLength": 1
          },
          "brand": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          },
          "traits_override": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "add": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z]+:[a-z][a-z0-9_]*$"
                }
              },
              "remove": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z]+:[a-z][a-z0-9_]*$"
                }
              }
            }
          }
        }
      }
    }
  }
}
