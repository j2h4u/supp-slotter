{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Traits Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "traits"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "traits": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z]+:[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "description", "applies_when"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "applies_when": {
            "type": "string",
            "minLength": 1
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["match"],
              "properties": {
                "match": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": false,
                  "properties": {
                    "near": {
                      "type": "string",
                      "enum": ["wake", "breakfast", "day_meal", "sleep", "workout_before", "workout_after"]
                    },
                    "food": {
                      "type": "boolean"
                    }
                  }
                },
                "level": {
                  "type": "string",
                  "enum": ["avoid_strong", "avoid", "prefer", "prefer_strong"]
                },
                "block": {
                  "type": "boolean",
                  "const": true
                }
              },
              "oneOf": [
                {"required": ["level"]},
                {"required": ["block"]}
              ]
            }
          },
          "separate_from": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z]+:[a-z][a-z0-9_]*$"
            }
          },
          "warning": {
            "type": "boolean",
            "const": true
          },
          "action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
