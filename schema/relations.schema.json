{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Substance Relations",
  "type": "object",
  "additionalProperties": false,
  "required": ["relations"],
  "properties": {
    "governance_defaults": {"$ref": "#/$defs/governance"},
    "relations": {"$ref": "#/$defs/relationList"}
  },
  "$defs": {
    "relationList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason"],
        "required": ["id", "type", "reason", "source_selector", "target_selector", "assertion_kind", "semantic_family"],
        "properties": {
          "id": {"type": "string", "pattern": "^rel_[a-z0-9_]+$"},
          "type": {"type": "string", "enum": ["balance", "supports", "competes", "review_with"]},
          "assertion_kind": {"type": "string", "enum": ["ontology_assertion", "clinical_review_signal"]},
          "semantic_family": {
            "type": "string",
            "enum": [
              "biochemical_mechanism_assertion",
              "absorption_interaction_claim",
              "nutritional_adequacy_advisory",
              "nutrient_balance_review_signal",
              "clinical_review_signal"
            ]
          },
          "source_selector": {"$ref": "#/$defs/selector"},
          "target_selector": {"$ref": "#/$defs/selector"},
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legacy_preserved", "status", "owner", "review_by", "evidence", "scope"],
      "properties": {
        "legacy_preserved": {"const": true},
        "status": {"const": "review_pending"},
        "owner": {"type": "string", "minLength": 1},
        "review_by": {"type": "string", "minLength": 1},
        "evidence": {"type": "array"},
        "scope": {"type": "object", "additionalProperties": false, "required": ["planner"], "properties": {"planner": {"type": "string", "minLength": 1}}}
      }
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {"required": ["entity"]},
        {"required": ["category", "term"]}
      ],
      "properties": {
        "entity": {
          "type": "object",
          "additionalProperties": false,
          "oneOf": [{"required": ["id"]}, {"required": ["name"]}],
          "properties": {
            "id": {"type": "string", "pattern": "^sub_[a-z0-9]+$"},
            "name": {"type": "string", "minLength": 1}
          }
        },
        "category": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "term": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
      }
    }
  }
}
