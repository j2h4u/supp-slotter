{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Substance Relations",
  "type": "object",
  "additionalProperties": false,
  "required": ["relations"],
  "properties": {"relations": {"$ref": "#/$defs/relationList"}},
  "$defs": {
    "relationList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason"],
        "required": ["id", "type", "reason", "source_selector", "target_selector"],
        "properties": {
          "id": {"type": "string", "pattern": "^rel_[a-z0-9_]+$"},
          "type": {"type": "string", "enum": ["balance", "supports", "competes", "review_with"]},
          "source_selector": {"$ref": "#/$defs/selector"},
          "target_selector": {"$ref": "#/$defs/selector"},
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        }
      }
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {"required": ["entity"]},
        {"required": ["category", "term"]}
      ],
      "properties": {
        "entity": {
          "type": "object",
          "additionalProperties": false,
          "oneOf": [{"required": ["id"]}, {"required": ["name"]}],
          "properties": {
            "id": {"type": "string", "pattern": "^sub_[a-z0-9]+$"},
            "name": {"type": "string", "minLength": 1}
          }
        },
        "category": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "term": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
      }
    }
  }
}
