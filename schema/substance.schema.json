{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Substance Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "traits"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^sub_[a-z0-9]{10}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "form": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "traits": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z]+:[a-z][a-z0-9_]*$"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "unmatched_concerns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prefer_with": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^sub_[a-z0-9]{10}$"
      }
    },
    "relations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "substances", "reason"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "balance",
              "supports",
              "supported_by",
              "competes_absorption",
              "antagonizes",
              "antagonized_by"
            ]
          },
          "substances": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^sub_[a-z0-9]{10}$"
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
