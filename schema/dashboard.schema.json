{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dashboard Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "taking"],
  "anyOf": [
    {"required": ["benefit"]},
    {"required": ["risk"]}
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "benefit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "started": {
      "type": "string",
      "minLength": 1
    },
    "taking": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "substance": {
            "type": "string",
            "pattern": "^sub_[a-z0-9]{10}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "oneOf": [
          {"required": ["substance"]},
          {"required": ["name"]}
        ]
      }
    }
  }
}
