{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dashboard Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "selectors"],
  "anyOf": [
    {"required": ["benefit"]},
    {"required": ["risk"]}
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "benefit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "selectors": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["category", "term"], "properties": {"category": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}, "term": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}}},
    "declares_context": {"type": "array", "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}
  }
}
