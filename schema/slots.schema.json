{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Slots Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "slots"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "slots": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "order", "stack", "near", "food"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "stack": {
            "type": "string",
            "enum": ["daily", "training"]
          },
          "near": {
            "type": "string",
            "enum": ["wake", "breakfast", "day_meal", "sleep", "workout_before", "workout_after"]
          },
          "food": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
